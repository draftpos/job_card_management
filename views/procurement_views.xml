<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_procurement_form" model="ir.ui.view">
        <field name="name">procurement.form</field>
        <field name="model">procurement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_for_approval" string="Submit for Approval" type="object" invisible="state not in ['draft']"/>
                    <button name="action_approve_requisition" string="Approve Requisition" type="object" invisible="state not in ['submitted_for_approval']"/>
                    <button name="action_create_purchase_order" string="Create Purchase Order" type="object" invisible="state not in ['approved']"/>
                    <button name="action_create_grv" string="Create GRV" type="object" invisible="state not in ['purchase_order_created']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="purchase_order_created_count" widget="statinfo" string="PO Created"/>
                        </button>
                        <button name="action_view_internal_transfers" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="internal_transfer_created_count" widget="statinfo" string="Transfers"/>
                        </button>
                        <button name="action_view_delivered_items" type="object" class="oe_stat_button" icon="fa-check-circle">
                            <field name="receipt_delivered_count" widget="statinfo" string="Delivered"/>
                        </button>
                    </div>
                    <field name="name"/>
                    <field name="job_card_id"/>
                    <group string="Procurement Lines">
                        <field name="procurement_lines">
                            <list editable="bottom">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="type"/>
                                <field name="vendor_id" invisible="type == 'internal_transfer'"/>
                                <field name="receipt_status"/>
                                <field name="purchase_order_created"/>
                                <field name="internal_transfer_created"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_procurement_list" model="ir.ui.view">
        <field name="name">procurement.list</field>
        <field name="model">procurement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="job_card_id"/>
                <field name="total_amount"/>
                <field name="create_uid"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_procurement" model="ir.actions.act_window">
        <field name="name">Procurement</field>
        <field name="res_model">procurement</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>