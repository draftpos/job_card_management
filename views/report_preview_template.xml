<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_preview_page" name="Report Preview">
        <t t-out="'&lt;!DOCTYPE html&gt;'"/>
        <html>
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
            <title><t t-out="title"/></title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #1a1a2e; overflow: hidden; height: 100vh; }
                .jc-loader-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; z-index: 1000; transition: opacity 0.4s ease; }
                .jc-loader-overlay.hidden { opacity: 0; pointer-events: none; }
                .jc-loader-card { background: #ffffff; padding: 40px 50px; border-radius: 20px; text-align: center; box-shadow: 0 32px 80px rgba(0,0,0,0.3); }
                .jc-lottie-container { width: 180px; height: 180px; margin: 0 auto; }
                .jc-loader-title { font-size: 16px; font-weight: 600; color: #495057; margin-top: 10px; }
                .jc-loader-subtitle { font-size: 13px; color: #868e96; margin-top: 4px; }
                .toolbar { background: #1a1a2e; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; color: white; border-bottom: 1px solid rgba(255,255,255,0.1); }
                .toolbar-title { font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 8px; }
                .toolbar-buttons { display: flex; gap: 6px; }
                .btn { padding: 7px 14px; border-radius: 6px; border: none; cursor: pointer; font-size: 12px; font-weight: 500; transition: all 0.15s; }
                .btn-print { background: rgba(255,255,255,0.1); color: #ccc; }
                .btn-print:hover { background: rgba(255,255,255,0.2); color: #fff; }
                .btn-download { background: #667eea; color: #fff; }
                .btn-download:hover { background: #5568d3; }
                .btn-close { background: #e5484d; color: #fff; }
                .btn-close:hover { background: #d14348; }
                .pdf-container { height: calc(100vh - 47px); background: #525659; }
                iframe { width: 100%; height: 100%; border: none; }
            </style>
        </head>
        <body>
            <div id="jc-loader" class="jc-loader-overlay">
                <div class="jc-loader-card">
                    <div id="jc-lottie" class="jc-lottie-container"></div>
                    <p class="jc-loader-title" t-out="title"/>
                    <p class="jc-loader-subtitle">Preparing your document...</p>
                </div>
            </div>
            
            <div id="jc-viewer" style="display:none; height:100vh;">
                <div class="toolbar">
                    <span class="toolbar-title">📄 <t t-out="title"/></span>
                    <div class="toolbar-buttons">
                        <button class="btn btn-print" onclick="window.print()">🖨 Print</button>
                        <button class="btn btn-download" id="jc-download-btn">⬇ Download</button>
                        <button class="btn btn-close" onclick="window.close()">✕ Close</button>
                    </div>
                </div>
                <div class="pdf-container">
                    <iframe id="jc-pdf-frame"></iframe>
                </div>
            </div>
            
            <script><![CDATA[
                var pdfUrl = '';
                async function loadPDF() {
                    try {
                        var resp = await fetch('/job_card_management/report/preview', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                record_id: ]]><t t-out="record_id"/><![CDATA[,
                                report_name: ']]><t t-out="report_name"/><![CDATA[',
                            }),
                        });
                        if (!resp.ok) throw new Error('Failed');
                        var blob = await resp.blob();
                        pdfUrl = URL.createObjectURL(blob);
                        document.getElementById('jc-loader').classList.add('hidden');
                        setTimeout(function() {
                            document.getElementById('jc-loader').style.display = 'none';
                            document.getElementById('jc-viewer').style.display = 'block';
                            document.getElementById('jc-pdf-frame').src = pdfUrl;
                        }, 500);
                        document.getElementById('jc-download-btn').onclick = function() {
                            var a = document.createElement('a');
                            a.href = pdfUrl;
                            a.download = ']]><t t-out="title"/><![CDATA[.pdf';
                            a.click();
                        };
                    } catch(e) {
                        document.getElementById('jc-loader').innerHTML = '<div class="jc-loader-card"><p style="color:#e5484d;font-size:16px;">Failed to generate PDF</p><p style="color:#868e96;font-size:13px;margin-top:8px;">Redirecting to download...</p></div>';
                        setTimeout(function() {
                            window.location.href = '/report/pdf/]]><t t-out="report_name"/><![CDATA[/]]><t t-out="record_id"/><![CDATA[';
                        }, 1500);
                    }
                }
                (function() {
                    var c = document.getElementById('jc-lottie');
                    if (!c) { loadPDF(); return; }
                    var s = document.createElement('script');
                    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js';
                    s.onload = function() {
                        try { lottie.loadAnimation({ container: c, renderer: 'svg', loop: true, autoplay: true, path: '/job_card_management/static/src/lottie/pdf_loader.json' }); } catch(e) {}
                        loadPDF();
                    };
                    s.onerror = function() { loadPDF(); };
                    document.head.appendChild(s);
                })();
            ]]></script>
        </body>
        </html>
    </template>
</odoo>