<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="estimates_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Header -->
                        <div style="background-color: #1a1a2e; padding: 30px 40px; font-family: Arial, sans-serif; margin: -20px -20px 0 -20px;">
                            <div style="color: #ffffff; font-size: 13px; font-weight: bold; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px;">Estimate Report</div>
                            <div style="color: #e0e4f0; font-size: 20px; font-weight: bold;" t-field="doc.name"/> 
                        </div>

                        <!-- Info Section -->
                        <div style="padding: 28px 40px; background-color: #f8f9fb; margin: 0 -20px;">
                            <table style="width: 100%; border: none; border-collapse: collapse;">
                                <tr>
                                    <td style="border: none; padding: 14px 20px; width: 50%; vertical-align: top;">
                                        <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; margin-bottom: 6px;">Customer</div>
                                        <div style="font-size: 18px; color: #1a1a2e; font-weight: bold;" t-field="doc.customer_id.name"/> 
                                    </td>
                                    <td style="border: none; padding: 14px 20px; width: 50%; vertical-align: top;">
                                        <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; margin-bottom: 6px;">Date</div>
                                        <div style="font-size: 18px; color: #1a1a2e; font-weight: bold;" t-field="doc.create_date"/> 
                                    </td>
                                </tr>
                                <tr>
                                    <td style="border: none; padding: 14px 20px; vertical-align: top;">
                                        <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; margin-bottom: 6px;">Vehicle</div>
                                        <div style="font-size: 18px; color: #1a1a2e; font-weight: bold;" t-field="doc.vehicle_id.name"/> 
                                    </td>
                                    <td style="border: none; padding: 14px 20px; vertical-align: top;">
                                        <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; margin-bottom: 6px;">Vehicle Model</div>
                                        <div style="font-size: 18px; color: #1a1a2e; font-weight: bold;" t-field="doc.vehicle_model"/> 
                                    </td>
                                </tr>
                                <tr>
                                    <td style="border: none; padding: 14px 20px; vertical-align: top;">
                                        <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; margin-bottom: 6px;">Vehicle ID</div>
                                        <div style="font-size: 18px; color: #1a1a2e; font-weight: bold;" t-field="doc.vehicle_id.registration_number"/> 
                                    </td>
                                    <td style="border: none; padding: 14px 20px; vertical-align: top;">
                                        <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; margin-bottom: 6px;">Estimator</div>
                                        <div style="font-size: 18px; color: #1a1a2e; font-weight: bold;" t-field="env.user.name"/> 
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Lines Table -->
                        <div style="padding: 30px 40px;">
                            <h3 style="font-size: 13px; font-weight: bold; color: #1a1a2e; margin: 0 0 20px 0; padding-bottom: 10px; border-bottom: 4px solid #1a1a2e; text-transform: uppercase; letter-spacing: 2px;">Estimate Lines</h3>

                            <table style="width: 100%; border: none; border-collapse: collapse;">
                                <thead>
                                    <tr style="background-color: #1a1a2e;">
                                        <th style="border: none; padding: 16px 20px; text-align: left; font-size: 12px; color: #ffffff; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; background-color: #1a1a2e; width: 35%;">Products</th>
                                        <th style="border: none; padding: 16px 20px; text-align: right; font-size: 12px; color: #ffffff; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; background-color: #1a1a2e; width: 20%;">Quantity</th>
                                        <th style="border: none; padding: 16px 20px; text-align: right; font-size: 12px; color: #ffffff; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; background-color: #1a1a2e; width: 12%;">Discount</th>
                                        <th style="border: none; padding: 16px 20px; text-align: right; font-size: 12px; color: #ffffff; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; background-color: #1a1a2e; width: 15%;">Subtotal</th>
                                        <th style="border: none; padding: 16px 20px; text-align: right; font-size: 12px; color: #ffffff; text-transform: uppercase; letter-spacing: 1.5px; font-weight: bold; background-color: #1a1a2e; width: 18%;">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.estimate_lines" t-as="line">
                                        <tr t-if="line.display_type == 'line_section'" style="background-color: #f1f3f5;">
                                            <td colspan="5" style="border: none; padding: 16px 20px; font-size: 18px; font-weight: bold; color: #1a1a2e; text-transform: uppercase; letter-spacing: 1px;"><t t-out="line.name"/></td>
                                        </tr>
                                        <tr t-elif="line.display_type == 'line_note'" style="background-color: #ffffff;">
                                            <td colspan="5" style="border: none; padding: 16px 20px; font-size: 16px; color: #bbbbbb; font-style: italic;"><t t-out="line.name"/></td>
                                        </tr>
                                        <tr t-else="" style="background-color: #ffffff;">
                                            <td style="border: none; padding: 16px 20px; font-size: 18px; color: #1a1a2e; font-weight: bold;"><span t-field="line.product_id.name"/></td>
                                            <td style="border: none; padding: 16px 20px; font-size: 16px; color: #555; text-align: right;"><span t-esc="line.quantity"/> <span style="color: #aaa; font-size: 13px;" t-field="line.product_uom_id.name"/></td>
                                            <td style="border: none; padding: 16px 20px; font-size: 16px; color: #555; text-align: right;"><t t-if="line.discount"><span t-esc="line.discount"/>%</t><t t-else="">—</t></td>
                                            <td style="border: none; padding: 16px 20px; font-size: 18px; color: #555; text-align: right;"><span t-esc="'$ {:.2f}'.format(line.price_subtotal)"/></td>
                                            <td style="border: none; padding: 16px 20px; font-size: 18px; color: #1a1a2e; text-align: right; font-weight: bold;"><span t-esc="'$ {:.2f}'.format(line.price_total)"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="background-color: #f1f3f5;">
                                        <td colspan="4" style="border: none; padding: 20px 20px; font-size: 22px; font-weight: bold; color: #1a1a2e; text-align: right; text-transform: uppercase; letter-spacing: 1px;">Total</td>
                                        <td style="border: none; padding: 20px 20px; font-size: 22px; font-weight: bold; color: #1a1a2e; text-align: right;"><span t-esc="'$ {:.2f}'.format(doc.amount_total)"/></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_estimate" model="ir.actions.report">
        <field name="name">Estimate Report PDF</field>
        <field name="model">estimate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">job_card_management.estimates_report</field>
        <field name="report_file">job_card_management.estimates_report</field>
        <field name="print_report_name">'Estimate Report - %s' % object.name</field>
    </record>

    <record id="action_estimate" model="ir.actions.act_window">
        <field name="name">Estimates</field>
        <field name="res_model">estimate</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_estimate_form" model="ir.ui.view">
        <field name="name">estimate.form</field>
        <field name="model">estimate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit for Approval" type="object" invisible="state not in ['draft']"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state not in ['submitted']"/>
                    <button name="action_open_job_card" string="Open Job Card" type="object" invisible="state not in ['approved'] or has_job_card"/>
                    <button name="action_preview_estimate" string="Print Estimate" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                <group col="2">
                    <group col="1" string="Estimate Details">
                        <field name="name" nolabel="1"/>
                        <field name="customer_id" nolabel="1"/>
                    </group>
                    <group col="1" string="Vehicle Details">
                        <field name="vehicle_id" nolabel="1"/>
                        <field name="vehicle_name" nolabel="1" readonly="1"/>
                        <field name="vehicle_model" nolabel="1" readonly="1"/>
                    </group>
                </group>
                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="estimate_lines" widget="section_and_note_one2many" nolabel="1">
                                <list editable="bottom" string="Estimate Lines">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" string="Product" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" string="Section/Note" invisible="display_type == False"/>
                                    <field name="quantity" string="Quantity" invisible="display_type != False"/>
                                    <field name="product_uom_id" string="UoM" required="not display_type" invisible="display_type != False" groups="uom.group_uom" width="80px"/>
                                    <field name="unit_price" string="Unit Price" invisible="display_type != False"/>
                                    <field name="tax_ids" string="Taxes" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" string="Disc.%" width="60px" invisible="display_type != False"/>
                                    <field name="price_subtotal" string="Subtotal" invisible="display_type != False" readonly="1"/>
                                    <field name="price_total" string="Amount" invisible="display_type != False" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <table class="float-end">
                        <tbody>
                            <tr>
                                <td class="o_td_label"><label for="amount_untaxed">Untaxed Amount</label></td>
                                <td><field name="amount_untaxed" widget="monetary" readonly="1"/></td>
                            </tr>
                            <tr>
                                <td class="o_td_label"><label for="amount_total">Total</label></td>
                                <td><field name="amount_total" widget="monetary" readonly="1"/></td>
                            </tr>
                        </tbody>
                    </table>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_estimate_list" model="ir.ui.view">
        <field name="name">estimate.list</field>
        <field name="model">estimate</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="vehicle_name"/>
                <field name="amount_total"/>
                <field name="create_uid"/>
                <field name="state"/>
            </list>
        </field>
    </record>

</odoo>